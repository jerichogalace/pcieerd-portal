// Prisma schema for PRODUCTION - Neon PostgreSQL
// 
// INSTRUCTIONS FOR RENDER DEPLOYMENT:
// 1. Copy this file content to prisma/schema.prisma before deploying
// 2. Or set the following environment variables in Render:
//    - DATABASE_URL: Your Neon pooled connection string
//    - DIRECT_DATABASE_URL: Your Neon direct connection string
// 3. The build command will automatically generate the Prisma client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Concern model - stores visitor concerns/submissions
model Concern {
  id              String   @id @default(cuid())
  fullName        String
  visitorType     String   // PCIEERD Employee, DOST Employee, etc.
  organization    String?  @default("")
  contactNumber   String?  @default("")
  email           String?  @default("")
  concernType     String   // Inquiry, Complaint, Request, Follow-up, Other
  concernDetails  String   @db.Text
  additionalNotes String?  @default("") @db.Text
  attachments     Json?    @default("[]") // Array of attachments as JSON
  dateSubmitted   String   // MM/DD/YYYY format
  timeSubmitted   String   // HH:MM:SS AM/PM format
  status          String   @default("Unread") // Unread, Pending, Completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([dateSubmitted])
  @@index([createdAt])
  @@map("concerns")
}

// Admin settings model - stores admin PIN and settings
model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}
