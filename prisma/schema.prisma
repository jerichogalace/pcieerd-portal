// Prisma schema for DOST-PCIEERD Concern Management System
// 
// FOR LOCAL DEVELOPMENT (SQLite):
// - Uses SQLite by default for easier local development
// - Database file: ./db/custom.db
//
// FOR PRODUCTION DEPLOYMENT (Neon PostgreSQL):
// - Change provider to "postgresql"
// - Set DATABASE_URL and DIRECT_DATABASE_URL environment variables
// - Run: prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Concern model - stores visitor concerns/submissions
model Concern {
  id              String   @id @default(cuid())
  fullName        String
  visitorType     String   // PCIEERD Employee, DOST Employee, etc.
  organization    String?  @default("")
  contactNumber   String?  @default("")
  email           String?  @default("")
  concernType     String   // Inquiry, Complaint, Request, Follow-up, Other
  concernDetails  String
  additionalNotes String?  @default("")
  attachments     String?  @default("[]") // JSON string of attachments array
  dateSubmitted   String   // MM/DD/YYYY format
  timeSubmitted   String   // HH:MM:SS AM/PM format
  status          String   @default("Unread") // Unread, Pending, Completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([dateSubmitted])
  @@map("concerns")
}

// Admin settings model - stores admin PIN and settings
model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}
